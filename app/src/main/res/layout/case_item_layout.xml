<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Reporter row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/account_logo"
                android:contentDescription="Avatar"
                app:tint="@color/text_label_blue" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Anonymous Reporter"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_label_blue" />

                <TextView
                    android:id="@+id/tvCaseDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Just now"
                    android:textSize="11sp"
                    android:textColor="@android:color/darker_gray" />
            </LinearLayout>
        </LinearLayout>

        <!-- Case image -->
        <ImageView
            android:id="@+id/ivCasePhoto"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:scaleType="centerCrop"
            android:src="@drawable/placeholder_animal"
            android:contentDescription="Case Photo" />

        <!-- Description -->
        <TextView
            android:id="@+id/tvCaseDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textSize="13sp"
            android:textColor="@android:color/darker_gray"
            android:lineSpacingMultiplier="1.4"
            android:maxLines="3"
            android:ellipsize="end" />

        <!-- Location -->
        <TextView
            android:id="@+id/tvCaseLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textSize="12sp"
            android:textColor="@color/text_label_blue"
            android:textStyle="italic"
            android:maxLines="2"
            android:ellipsize="end" />

        <!-- Status badge -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Pending"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:background="@drawable/bg_btn_pink_shadow"
            android:paddingHorizontal="20dp"
            android:paddingVertical="6dp" />
    </LinearLayout>
</androidx.cardview.widget.CardView>